# ─── Security ─────────────────────────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=24

# ─── HuggingFace Inference API ────────────────────────────────────────────────
# Free key (no GPU needed): https://huggingface.co/settings/tokens
# Models used: facebook/bart-large-cnn, google/flan-t5-large, all-MiniLM-L6-v2
HF_API_KEY=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Database ─────────────────────────────────────────────────────────────────
# SQLite (development)
# DATABASE_URL=sqlite+aiosqlite:///./docuchat.db
# PostgreSQL (production) — uncomment and fill in:
DATABASE_URL=postgresql://postgres:[docuchat2026]@db.zmzjjslzyjlipehrsril.supabase.co:5432/postgres

# ─── Email / OTP ──────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=DocuChat <your@gmail.com>

# ─── File Upload ──────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10

# ─── CORS ─────────────────────────────────────────────────────────────────────
