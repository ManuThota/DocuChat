# ─── Security ─────────────────────────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=24

# ─── HuggingFace Inference API ────────────────────────────────────────────────
# Free key (no GPU needed): https://huggingface.co/settings/tokens
# Models used: facebook/bart-large-cnn, google/flan-t5-large, all-MiniLM-L6-v2
HF_API_KEY=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Groq API ─────────────────────────────────────────────────────────────────
# Free key (no credit card): https://console.groq.com/keys
# Used for: chat / Q&A — 14,400 req/day free with Llama 3.1
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Database ─────────────────────────────────────────────────────────────────
# SQLite (development)
# DATABASE_URL=sqlite+aiosqlite:///./docuchat.db
# PostgreSQL (production) — uncomment and fill in:
DATABASE_URL=postgresql://postgres:[pasword]@db.################.supabase.co:####/postgres

# ─── Email / OTP (Brevo Transactional API) ───────────────────────────────────
# SMTP is blocked on free cloud tiers. Brevo uses HTTPS (port 443) — always works.
# Sign up at: https://app.brevo.com → Settings → API Keys → Create (300 emails/day free)
BREVO_API_KEY=your-brevo-api-key-here
# Must match a sender address verified in your Brevo account:
EMAIL_FROM=DocuChat <your-verified@email.com>

# ─── File Upload ──────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=50

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
